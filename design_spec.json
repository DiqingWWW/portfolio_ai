{
  "name": "Portfolio OS - Figma Workspace Style",
  "style": "minimal design workspace / Figma-like canvas",

  "typography": {
    "fontFamily": "Helvetica Neue",
    "baseColor": "#373737",

    "h1": { "size": 48, "weight": 900, "lineHeight": 1.1, "letterSpacing": "-0.025em" },
    "h2": { "size": 24, "weight": 600 },
    "body": { "size": 16, "weight": 400 },
    "caption": { "size": 13, "weight": 300 },
    "subtitle": { "size": 24, "weight": 300, "letterSpacing": "0.05em", "color": "#737373" }
  },

  "color": {
    "background": "#F5F5F5",
    "text": "#373737",
    "grid": "rgba(55,55,55,0.04)",
    "accent": "#107ECF",
    "hoverAccent": "#2563EB",
    "subtitleText": "#737373",
    "accentAmber": "#FBBF24"
  },

  "spacing": {
    "base": 16,
    "scale": [8, 12, 16, 24, 32, 48, 64, 96, 120]
  },

  "motion": {
    "hoverDuration": 400,
    "hoverEasing": "cubic-bezier(0.16, 1, 0.3, 1)",
    "hoverScale": {
      "node": 1.05,
      "folder": 1.06
    }
  },

  "layout": {
    "gridVisible": true,
    "gridOpacity": 0.04,
    "structure": "asymmetric canvas",
    "density": "low-medium",
    "visualRule": "weight concentrated center-right (folder dominant)"
  }
}
